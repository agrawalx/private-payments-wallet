# ── Rust ────────────────────────────────────────────────────────────────
# Build output (huge: ~26 GB). Cargo regenerates it.
/target
**/target
*.rs.bk
# Keep Cargo.lock checked in (this is an app workspace, not a library).

# ── Vendored stellar-private-payments fork (vendor/) ───────────────────
# Source is committed; build output / fetched JS deps are not.
vendor/**/target
vendor/**/node_modules
# circuits build.rs clones circomlib into src/circomlib at build time.
vendor/circuits/src/circomlib/
# circuits build.rs also (re)generates a fresh, non-deterministic Groth16
# trusted setup into vendor/testdata/ on first build if it's empty. The real
# proving keys the app ships are the ones already committed under
# prover-ffi/circuits/ (baked in via include_bytes!); this is just build.rs
# scratch output for the vendored `circuits` crate itself.
vendor/testdata/

# ── Android / Gradle ────────────────────────────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/captures/
android/.externalNativeBuild/
android/.cxx/
android/local.properties          # machine-specific SDK path
*.apk
*.aab
*.ap_
*.dex

# Generated native libs. arm64-v8a (device) IS committed so `git clone && ./gradlew`
# builds a runnable APK with no Rust/NDK toolchain. Rebuild:
#   cargo ndk -t arm64-v8a -o android/app/src/main/jniLibs build -p prover-ffi --release
# x86_64 (emulator-only) stays ignored.
android/app/src/main/jniLibs/x86_64/

# Deploy build artifacts (fetched wasm + packaged bundle) — not source.
deploy/wasm/
deploy/aws/pp-deploy.tgz

# Terraform state + generated SSH key (secrets / machine-local).
deploy/aws/.terraform/
deploy/aws/*.tfstate
deploy/aws/*.tfstate.*
deploy/aws/pp-key.pem

# Generated UniFFI bindings — regenerated by the `uniffi-bindgen` bin.
# (The copy under android/app/src/main/java/uniffi/ is the one the app builds against.)
prover-ffi/bindings/

# ── IDEs / editors ──────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*~

# ── OS junk ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Secrets / keys (never commit) ───────────────────────────────────────
# Stellar/wallet secrets, signing keystores, OAuth client configs, env files.
*.keystore
*.jks
keystore.properties
google-services.json
*.pem
*.key
.env
.env.*
secrets.*

session.txt

# Keep (do NOT ignore) — these are committed assets the build needs:
#   prover-ffi/circuits/*.bin  *.r1cs  *.wasm   (embedded via include_bytes!)
#   prover-ffi/fixtures/*.json                  (params templates)
#   android/app/src/main/res/font/*.ttf         (bundled brand fonts)

# Ceremony artifacts: ptau is a 145M public download (re-fetch by hash);
# intermediate zkeys are scratch. The FINAL zkey + VK are committed.
vendor/ceremony/*.ptau
vendor/ceremony/*_0000.zkey
vendor/ceremony/*_0001.zkey
