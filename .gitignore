# ── Rust ────────────────────────────────────────────────────────────────
# Build output (huge: ~26 GB). Cargo regenerates it.
/target
**/target
*.rs.bk
# Keep Cargo.lock checked in (this is an app workspace, not a library).

# ── Android / Gradle ────────────────────────────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/captures/
android/.externalNativeBuild/
android/.cxx/
android/local.properties          # machine-specific SDK path
*.apk
*.aab
*.ap_
*.dex

# Generated native libs — rebuilt with `cargo ndk -t arm64-v8a -o android/app/src/main/jniLibs build -p prover-ffi --release`
android/app/src/main/jniLibs/

# Generated UniFFI bindings — regenerated by the `uniffi-bindgen` bin.
# (The copy under android/app/src/main/java/uniffi/ is the one the app builds against.)
prover-ffi/bindings/

# ── IDEs / editors ──────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*~

# ── OS junk ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Secrets / keys (never commit) ───────────────────────────────────────
# Stellar/wallet secrets, signing keystores, OAuth client configs, env files.
*.keystore
*.jks
keystore.properties
google-services.json
*.pem
*.key
.env
.env.*
secrets.*

session.txt

# Keep (do NOT ignore) — these are committed assets the build needs:
#   prover-ffi/circuits/*.bin  *.r1cs  *.wasm   (embedded via include_bytes!)
#   prover-ffi/fixtures/*.json                  (params templates)
#   android/app/src/main/res/font/*.ttf         (bundled brand fonts)
